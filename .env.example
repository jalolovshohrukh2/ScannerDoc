# --- Backend (used in development; in prod set these on Railway) ---

PORT=4000

# Comma-separated list of allowed CORS origins.
# Local dev:    http://localhost:5173
# Production:   https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# Token gating /uploads/:id. Required in production. Generate a long random string.
UPLOAD_TOKEN=dev-local-token-change-me

# OCR engine selection: 'tesseract' (offline) or 'google' (recommended)
OCR_ENGINE=tesseract

# Required when OCR_ENGINE=google. Get one from https://console.cloud.google.com/
# (create project -> enable "Cloud Vision API" -> Credentials -> API key).
# Pricing: ~$1.50 per 1000 scans. First 1000 / month free.
GOOGLE_VISION_API_KEY=

# Optional: persistent locations on the host (Railway volume mount).
# Defaults to ./uploads and ./data.sqlite inside the working directory.
# UPLOADS_DIR=/data/uploads
# DB_PATH=/data/data.sqlite

# Set to 1 to log raw OCR text to backend console (debugging).
SCAN_DEBUG=0

# --- Frontend (used by Vite at build time; set in Vercel project env vars) ---

# Absolute URL of the deployed backend. Leave empty for local dev (Vite proxies /api).
# Example: VITE_API_URL=https://scannerdoc-backend.up.railway.app
VITE_API_URL=
